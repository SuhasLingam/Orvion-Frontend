# When adding additional environment variables, update the schema in "src/env.js" accordingly.

# FastAPI backend base URL — no trailing slash.
# Local development: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Supabase (kept for the server-side /api/enroll route only — not used in the dashboard)
DATABASE_URL="postgresql://..."
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
